<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>المجدّد</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>

	<!-- Geolocation: prayer times + Qibla direction -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>يستخدم تطبيق المجدّد موقعك لحساب مواقيت الصلاة واتجاه القبلة.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>يستخدم تطبيق المجدّد موقعك لحساب مواقيت الصلاة واتجاه القبلة.</string>

	<!-- Camera: rakaat counter brightness detection -->
	<key>NSCameraUsageDescription</key>
	<string>تستخدم ميزة عدّاد الركعات الكاميرا الأمامية للكشف عن وضع السجود بدون تسجيل أو رفع.</string>

	<!-- Motion: orientation mode in rakaat counter -->
	<key>NSMotionUsageDescription</key>
	<string>يستخدم عدّاد الركعات مستشعر الحركة للكشف عن الأوضاع أثناء الصلاة.</string>

	<!-- Microphone + Speech Recognition: tasmee (memorization test) -->
	<key>NSMicrophoneUsageDescription</key>
	<string>يُستخدم الميكروفون لميزة تسميع الحفظ. قد يُرسَل صوتك لخدمة Apple للتعرّف على الكلام للمعالجة — لا يُخزَّن أي صوت في التطبيق ولا يُرفَع لخوادمنا.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>يستخدم تطبيق المجدّد ميزة التعرّف على الكلام لتسميع الحفظ ومطابقة ما تقرأه مع الآيات. قد يُرسَل صوتك لخوادم Apple للمعالجة — لا يُخزَّن أي صوت لدينا.</string>

	<!-- Google Sign-In redirect URL (REVERSED_CLIENT_ID from GoogleService-Info.plist) -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.ddcbusiness.noor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.911972197466-urmirpvsa2necvmkshj3pi3s3jd99888</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
