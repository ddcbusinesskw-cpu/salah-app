<?xml version="1.0" encoding="utf-8"?>
<!-- API 31+: قواعد النسخ السحابي ونقل جهاز-لجهاز.
     نستثني كاش النماذج الضخم وحالة الجلسة الحسّاسة من كليهما. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="app_webview/Default/Service Worker" />
        <exclude domain="file" path="app_webview/Default/Cache" />
        <exclude domain="file" path="app_webview/Default/blob_storage" />
        <exclude domain="file" path="app_webview/Default/IndexedDB" />
        <exclude domain="sharedpref" path="CapacitorStorage.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="app_webview/Default/Service Worker" />
        <exclude domain="file" path="app_webview/Default/Cache" />
        <exclude domain="file" path="app_webview/Default/blob_storage" />
        <exclude domain="file" path="app_webview/Default/IndexedDB" />
    </device-transfer>
</data-extraction-rules>
